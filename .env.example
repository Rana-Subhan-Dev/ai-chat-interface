# ============================================================
# AI Chat Interface — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file.
#
# Currently the app uses a mock AI — no API key needed.
# When you're ready to connect a real AI provider, add keys here.
# ============================================================

# Optional: OpenAI API key (for future real AI integration)
# Get yours at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: App title override
VITE_APP_TITLE=AI Chat
